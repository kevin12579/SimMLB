# ──────────────────────────────────────────
# Database
# ──────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mlb_prediction
POSTGRES_USER=mlb_user
POSTGRES_PASSWORD=mlbpred123

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ──────────────────────────────────────────
# LLM (OpenAI 기본 / Groq로 전환 가능)
# ──────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ──────────────────────────────────────────
# Notifications
# ──────────────────────────────────────────
DISCORD_WEBHOOK_URL=
SENTRY_DSN=

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
